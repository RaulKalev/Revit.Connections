<Window
    x:Class="Connections.UI.ConnectionsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Connections"
    xmlns:ui="clr-namespace:Connections.UI"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Connections"
    Width="300"
    Height="480"
    MinWidth="220"
    MinHeight="380"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStyle="None"
    MouseMove="Window_MouseMove"
    PreviewKeyDown="Window_PreviewKeyDown"
    PreviewKeyUp="Window_PreviewKeyUp"
    mc:Ignorable="av">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <SolidColorBrush x:Key="PrimaryBackgroundBrush" Color="#FF1F1F1F" />
                    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#FF292929" />
                    <SolidColorBrush x:Key="BorderBrush" Color="#FF444444" />
                    <SolidColorBrush x:Key="ForegroundBrush" Color="#EEEEEE" />
                    <ui:BoolToVisibilityConverter x:Key="BoolToVisibility" />
                </ResourceDictionary>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.ComboBox.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Dark.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Connections;component/UI/Themes/ElementStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="Transparent" ClipToBounds="True">
        <!-- Outer Border with Opacity and Blur -->
        <Border
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="2"
            ClipToBounds="True"
            CornerRadius="10"
            Opacity="0.7"
            SnapsToDevicePixels="True">
            <Border.Effect>
                <BlurEffect KernelType="Gaussian" Radius="2" />
            </Border.Effect>
        </Border>

        <!-- Content Container -->
        <Border
            Margin="2"
            Background="{DynamicResource PrimaryBackgroundBrush}"
            CornerRadius="10">
            <Grid x:Name="MainContentGrid" PreviewMouseDown="Window_PreviewMouseDown">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <ui:TitleBar
                    Grid.Row="0"
                    Foreground="{DynamicResource ForegroundBrush}"
                    Loaded="TitleBar_Loaded" />

                <!-- Theme toggle -->
                <ToggleButton
                    x:Name="ThemeToggleButton"
                    Grid.Row="0"
                    Width="28"
                    Height="15.5"
                    Margin="0,0,70,0"
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Click="ToggleTheme_Click"
                    IsChecked="True"
                    ToolTip="Toggle Theme">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                            <Grid Background="Transparent">
                                <materialDesign:PackIcon
                                    x:Name="ThemeToggleIcon"
                                    Width="30"
                                    Height="30"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource IconBrush}"
                                    Kind="ToggleSwitchOffOutline" />
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="ThemeToggleIcon" Property="Kind" Value="ToggleSwitchOffOutline" />
                                </Trigger>
                                <Trigger Property="IsChecked" Value="False">
                                    <Setter TargetName="ThemeToggleIcon" Property="Kind" Value="ToggleSwitchOutline" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>

                <!-- Main Form Content (tabbed) -->
                <TabControl x:Name="MainTabControl"
                            Grid.Row="1"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            SelectionChanged="MainTabControl_SelectionChanged">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Foreground" Value="#BBBBBB" />
                            <Setter Property="FontSize" Value="12" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border x:Name="TabBorder"
                                                Background="#FF292929"
                                                CornerRadius="4,4,0,0"
                                                Margin="0,4,3,0"
                                                Padding="12,5">
                                            <ContentPresenter ContentSource="Header"
                                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="TabBorder" Property="Background" Value="#FF1F1F1F" />
                                                <Setter Property="Foreground" Value="#EEEEEE" />
                                            </Trigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsMouseOver, ElementName=TabBorder}" Value="True" />
                                                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter TargetName="TabBorder" Property="Background" Value="#FF363636" />
                                            </MultiDataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <Style TargetType="TabControl">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabControl">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <TabPanel Grid.Row="0"
                                                      IsItemsHost="True"
                                                      Background="Transparent"
                                                      Margin="0,0,0,0" />
                                            <Border Grid.Row="1"
                                                    Background="Transparent"
                                                    BorderThickness="0">
                                                <ContentPresenter ContentSource="SelectedContent" />
                                            </Border>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>

                    <!-- ═══════════════ NEW TAB ═══════════════ -->
                    <TabItem Header="New">
                        <Grid Margin="16,8,16,14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" /> <!-- 0: Panel label -->
                                <RowDefinition Height="6" />    <!-- 1: spacing -->
                                <RowDefinition Height="Auto" /> <!-- 2: ComboBox -->
                                <RowDefinition Height="Auto" /> <!-- 3: Existing connections text -->
                                <RowDefinition Height="6" />    <!-- 4: spacing -->
                                <RowDefinition Height="Auto" /> <!-- 5: labels row -->
                                <RowDefinition Height="4" />    <!-- 6: spacing -->
                                <RowDefinition Height="Auto" /> <!-- 7: inputs row -->
                                <RowDefinition Height="16" />   <!-- 8: spacing -->
                                <RowDefinition Height="Auto" /> <!-- 9: Param Name label -->
                                <RowDefinition Height="6" />    <!-- 10: spacing -->
                                <RowDefinition Height="Auto" /> <!-- 11: Param Name TextBox -->
                                <RowDefinition Height="12" />   <!-- 12: spacing -->
                                <RowDefinition Height="Auto" /> <!-- 13: Param Value label -->
                                <RowDefinition Height="6" />    <!-- 14: spacing -->
                                <RowDefinition Height="Auto" /> <!-- 15: Param Value TextBox -->
                                <RowDefinition Height="16" />   <!-- 16: spacing -->
                                <RowDefinition Height="Auto" /> <!-- 17: Checkboxes -->
                                <RowDefinition Height="10" />   <!-- 18: spacing -->
                                <RowDefinition Height="Auto" /> <!-- 19: Session counter -->
                                <RowDefinition Height="16" />   <!-- 20: spacing -->
                                <RowDefinition Height="Auto" /> <!-- 21: Button -->
                                <RowDefinition Height="6" />    <!-- 22: spacing -->
                                <RowDefinition Height="Auto" /> <!-- 23: Clear Warnings button -->
                                <RowDefinition Height="10" />   <!-- 24: spacing -->
                                <RowDefinition Height="*" />    <!-- 25: Result text -->
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Panel"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="11" FontWeight="SemiBold" />

                            <ComboBox Grid.Row="2"
                                      x:Name="PanelComboBox"
                                      Style="{StaticResource DarkThemeComboBox}"
                                      IsTextSearchEnabled="True"
                                      TextSearch.TextPath="Name"
                                      SelectionChanged="PanelComboBox_SelectionChanged"
                                      HorizontalAlignment="Stretch" />

                            <TextBlock Grid.Row="3"
                                       x:Name="ExistingConnectionsText"
                                       Text=""
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="10" Opacity="0.7"
                                       Margin="0,2,0,0" />

                            <Grid Grid.Row="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Connection Limit (0=∞)"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           FontSize="11" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="2"
                                           Text="Max Cable Length m (0=off)"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           FontSize="11" FontWeight="SemiBold" />
                            </Grid>

                            <Grid Grid.Row="7">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         x:Name="ConnectionLimitBox"
                                         Text="0"
                                         Style="{StaticResource CustomTextBoxStyle}"
                                         HorizontalAlignment="Stretch"
                                         PreviewTextInput="NumericOnly_PreviewTextInput" />
                                <TextBox Grid.Column="2"
                                         x:Name="MaxCableLengthBox"
                                         Text="0"
                                         Style="{StaticResource CustomTextBoxStyle}"
                                         HorizontalAlignment="Stretch"
                                         PreviewTextInput="NumericOnly_PreviewTextInput" />
                            </Grid>

                            <TextBlock Grid.Row="9"
                                       Text="Circuit Parameter Name"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="11" FontWeight="SemiBold" />

                            <TextBox Grid.Row="11"
                                     x:Name="CircuitParamNameBox"
                                     Style="{StaticResource CustomTextBoxStyle}"
                                     HorizontalAlignment="Stretch" />

                            <TextBlock Grid.Row="13"
                                       Text="Circuit Parameter Value"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="11" FontWeight="SemiBold" />

                            <TextBox Grid.Row="15"
                                     x:Name="CircuitParamValueBox"
                                     Style="{StaticResource CustomTextBoxStyle}"
                                     HorizontalAlignment="Stretch" />

                            <StackPanel Grid.Row="17" Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox x:Name="ConnectIndividuallyCheck"
                                          Content="Connect Individually"
                                          IsChecked="True"
                                          Checked="ConnectIndividuallyCheck_Checked"
                                          Style="{StaticResource CustomCheckboxStyleCompact}"
                                          Margin="0,0,20,0" />
                                <CheckBox x:Name="ConnectCombinedCheck"
                                          Content="Connect Combined"
                                          IsChecked="False"
                                          Checked="ConnectCombinedCheck_Checked"
                                          Style="{StaticResource CustomCheckboxStyleCompact}" />
                            </StackPanel>

                            <Grid Grid.Row="19">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="SessionCounterText"
                                           Grid.Column="0"
                                           Text="Connections: 0"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           FontSize="12" FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Button x:Name="ClearCounterButton"
                                        Grid.Column="1"
                                        Content="Clear"
                                        Click="ClearCounterButton_Click"
                                        Style="{StaticResource CustomActionButtonStyle}"
                                        Height="24" Width="52"
                                        FontSize="11"
                                        Padding="6,0" />
                            </Grid>

                            <Button Grid.Row="21"
                                    x:Name="SelectConnectButton"
                                    Content="Select Elements &amp; Connect"
                                    Click="SelectConnectButton_Click"
                                    Style="{StaticResource CustomActionButtonStyle}"
                                    Width="Auto"
                                    HorizontalAlignment="Stretch"
                                    Height="34" />

                            <Button Grid.Row="23"
                                    x:Name="ClearWarningsButton"
                                    Content="Clear Warnings"
                                    Click="ClearWarningsButton_Click"
                                    Style="{StaticResource CustomActionButtonStyle}"
                                    Visibility="Collapsed"
                                    Width="Auto"
                                    HorizontalAlignment="Stretch"
                                    Height="28"
                                    FontSize="11"
                                    Opacity="0.85" />

                            <ScrollViewer Grid.Row="25" VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="ResultText"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Top"
                                           Opacity="0.85" />
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <!-- ═══════════════ EXISTING TAB ═══════════════ -->
                    <TabItem Header="Existing">
                        <Grid Margin="16,8,16,14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" /> <!-- 0: Panel label -->
                                <RowDefinition Height="6" />    <!-- 1: spacing -->
                                <RowDefinition Height="Auto" /> <!-- 2: ComboBox -->
                                <RowDefinition Height="Auto" /> <!-- 3: Existing connections text -->
                                <RowDefinition Height="6" />    <!-- 4: spacing -->
                                <RowDefinition Height="Auto" /> <!-- 5: labels row -->
                                <RowDefinition Height="4" />    <!-- 6: spacing -->
                                <RowDefinition Height="Auto" /> <!-- 7: inputs row -->
                                <RowDefinition Height="16" />   <!-- 8: spacing -->
                                <RowDefinition Height="Auto" /> <!-- 9: Param Name label -->
                                <RowDefinition Height="6" />    <!-- 10: spacing -->
                                <RowDefinition Height="Auto" /> <!-- 11: Param Name TextBox -->
                                <RowDefinition Height="12" />   <!-- 12: spacing -->
                                <RowDefinition Height="Auto" /> <!-- 13: Param Value label -->
                                <RowDefinition Height="6" />    <!-- 14: spacing -->
                                <RowDefinition Height="Auto" /> <!-- 15: Param Value TextBox -->
                                <RowDefinition Height="26" />   <!-- 16: spacing (checkboxes replaced) -->
                                <RowDefinition Height="Auto" /> <!-- 17: Session counter -->
                                <RowDefinition Height="16" />   <!-- 18: spacing -->
                                <RowDefinition Height="Auto" /> <!-- 19: Button -->
                                <RowDefinition Height="6" />    <!-- 20: spacing -->
                                <RowDefinition Height="Auto" /> <!-- 21: Clear Warnings button -->
                                <RowDefinition Height="10" />   <!-- 22: spacing -->
                                <RowDefinition Height="*" />    <!-- 23: Result text -->
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Panel"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="11" FontWeight="SemiBold" />

                            <ComboBox Grid.Row="2"
                                      x:Name="Ex_PanelComboBox"
                                      Style="{StaticResource DarkThemeComboBox}"
                                      IsTextSearchEnabled="True"
                                      TextSearch.TextPath="Name"
                                      SelectionChanged="Ex_PanelComboBox_SelectionChanged"
                                      HorizontalAlignment="Stretch" />

                            <TextBlock Grid.Row="3"
                                       x:Name="Ex_ExistingConnectionsText"
                                       Text=""
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="10" Opacity="0.7"
                                       Margin="0,2,0,0" />

                            <Grid Grid.Row="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Connection Limit (0=∞)"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           FontSize="11" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="2"
                                           Text="Max Cable Length m (0=off)"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           FontSize="11" FontWeight="SemiBold" />
                            </Grid>

                            <Grid Grid.Row="7">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         x:Name="Ex_ConnectionLimitBox"
                                         Text="0"
                                         Style="{StaticResource CustomTextBoxStyle}"
                                         HorizontalAlignment="Stretch"
                                         PreviewTextInput="NumericOnly_PreviewTextInput" />
                                <TextBox Grid.Column="2"
                                         x:Name="Ex_MaxCableLengthBox"
                                         Text="0"
                                         Style="{StaticResource CustomTextBoxStyle}"
                                         HorizontalAlignment="Stretch"
                                         PreviewTextInput="NumericOnly_PreviewTextInput" />
                            </Grid>

                            <TextBlock Grid.Row="9"
                                       Text="Circuit Parameter Name"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="11" FontWeight="SemiBold" />

                            <TextBox Grid.Row="11"
                                     x:Name="Ex_CircuitParamNameBox"
                                     Style="{StaticResource CustomTextBoxStyle}"
                                     HorizontalAlignment="Stretch" />

                            <TextBlock Grid.Row="13"
                                       Text="Circuit Parameter Value"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="11" FontWeight="SemiBold" />

                            <TextBox Grid.Row="15"
                                     x:Name="Ex_CircuitParamValueBox"
                                     Style="{StaticResource CustomTextBoxStyle}"
                                     HorizontalAlignment="Stretch" />

                            <!-- Row 16: spacer (replaces checkboxes) -->

                            <Grid Grid.Row="17">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="Ex_SessionCounterText"
                                           Grid.Column="0"
                                           Text="Reassigned: 0"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           FontSize="12" FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Button x:Name="Ex_ClearCounterButton"
                                        Grid.Column="1"
                                        Content="Clear"
                                        Click="Ex_ClearCounterButton_Click"
                                        Style="{StaticResource CustomActionButtonStyle}"
                                        Height="24" Width="52"
                                        FontSize="11"
                                        Padding="6,0" />
                            </Grid>

                            <Button Grid.Row="19"
                                    x:Name="ReassignButton"
                                    Content="Select Elements &amp; Reassign"
                                    Click="ReassignButton_Click"
                                    Style="{StaticResource CustomActionButtonStyle}"
                                    Width="Auto"
                                    HorizontalAlignment="Stretch"
                                    Height="34" />

                            <Button Grid.Row="21"
                                    x:Name="Ex_ClearWarningsButton"
                                    Content="Clear Warnings"
                                    Click="Ex_ClearWarningsButton_Click"
                                    Style="{StaticResource CustomActionButtonStyle}"
                                    Visibility="Collapsed"
                                    Width="Auto"
                                    HorizontalAlignment="Stretch"
                                    Height="28"
                                    FontSize="11"
                                    Opacity="0.85" />

                            <ScrollViewer Grid.Row="23" VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="Ex_ResultText"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Top"
                                           Opacity="0.85" />
                            </ScrollViewer>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>

        <!-- Resize edges -->
        <Border x:Name="LeftEdge" Width="5" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                Background="Transparent" Cursor="SizeWE" Panel.ZIndex="3000"
                MouseEnter="LeftEdge_MouseEnter" MouseLeave="Edge_MouseLeave"
                MouseLeftButtonDown="LeftEdge_MouseLeftButtonDown" />
        <Border x:Name="RightEdge" Width="9" HorizontalAlignment="Right" VerticalAlignment="Stretch"
                Background="Transparent" Cursor="SizeWE" Panel.ZIndex="3000"
                MouseEnter="RightEdge_MouseEnter" MouseLeave="Edge_MouseLeave"
                MouseLeftButtonDown="RightEdge_MouseLeftButtonDown" />
        <Border x:Name="BottomEdge" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                Background="Transparent" Cursor="SizeNS" Panel.ZIndex="3000"
                MouseEnter="BottomEdge_MouseEnter" MouseLeave="Edge_MouseLeave"
                MouseLeftButtonDown="BottomEdge_MouseLeftButtonDown" />
        <Border x:Name="BottomLeftCorner" Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Background="Transparent" Cursor="SizeNESW" Panel.ZIndex="3000"
                MouseEnter="BottomLeftCorner_MouseEnter" MouseLeave="Edge_MouseLeave"
                MouseLeftButtonDown="BottomLeftCorner_MouseLeftButtonDown" />
        <Border x:Name="BottomRightCorner" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Background="Transparent" Cursor="SizeNWSE" Panel.ZIndex="3000"
                MouseEnter="BottomRightCorner_MouseEnter" MouseLeave="Edge_MouseLeave"
                MouseLeftButtonDown="BottomRightCorner_MouseLeftButtonDown" />
    </Grid>
</Window>
